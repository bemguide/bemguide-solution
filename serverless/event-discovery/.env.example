# Required for the Vercel cron endpoint to authenticate requests.
# Vercel automatically sends "Authorization: Bearer $CRON_SECRET" with cron triggers.
# Generate any high-entropy random string and set in Vercel project env.
CRON_SECRET=

# OpenAI — used by the classify, geo-filter, and mapper steps
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Tavily Search API — discovery layer
TAVILY_API_KEY=

# Supabase — write target
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Run scope (defaults are tuned for 1 city, last 24h)
REGION_ID=dnipro
TIME_RANGE=day
SEARCH_DEPTH=advanced
MAX_RESULTS=20
CONCURRENCY=5
MIN_CONFIDENCE=0.5

# Geocoding — Photon (OSM, no API key)
GEOCODE_FALLBACK_LAT=48.4647
GEOCODE_FALLBACK_LNG=35.0462
DEFAULT_CITY=Дніпро
DEFAULT_OBLAST=Дніпропетровська

# Idempotency — how many days back to look for already-imported post URLs
DEDUP_LOOKBACK_DAYS=7
