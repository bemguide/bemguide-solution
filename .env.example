# Supabase (server-side only — never expose service role to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key is optional for MVP (we go SSR-only); add only if client realtime is enabled.
SUPABASE_ANON_KEY=
# Postgres connection string used by `supabase db push`.
SUPABASE_DB_URL=

# Google Gemini
GEMINI_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Same bot username, exposed to the client so the share helper can
# build `https://t.me/<bot>?startapp=evt_<id>` deep links — when set,
# tapping a shared event link opens the Mini App instead of the
# public web page. Leave empty to fall back to /event/[id] URLs.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Public app URL (Vercel deploy domain). Used by bot deep links and ICS generation.
NEXT_PUBLIC_APP_URL=

# Admin panel password gate.
ADMIN_PASSWORD=

# v2 backend (owned by another team). Frontend hits this via apps/web/lib/api/.
# Leave empty until the contract is wired — apiFetch will throw clearly.
NEXT_PUBLIC_API_BASE=
