# Supabase (server-side only — never expose service role to client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Anon key is optional for MVP (we go SSR-only); add only if client realtime is enabled.
SUPABASE_ANON_KEY=
# Postgres connection string used by `supabase db push`.
SUPABASE_DB_URL=

# Google Gemini
GEMINI_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Same bot username exposed to the client. `next.config.ts` mirrors
# the bare TELEGRAM_BOT_USERNAME above onto both public names at
# build time, so setting any one of these is enough.
#   NEXT_PUBLIC_TG_BOT_USERNAME       — team convention
#   NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — older name, kept for compat
NEXT_PUBLIC_TG_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# Public app URL (Vercel deploy domain). Used by bot deep links and ICS generation.
NEXT_PUBLIC_APP_URL=

# Admin panel password gate.
ADMIN_PASSWORD=

# v2 backend (owned by another team).
#
# In production the browser hits the same-origin proxy at `/api/v2/...`
# (defined by apps/web/app/api/v2/[...path]/route.ts). The proxy reads
# the upstream URL from `V2_API_BASE_URL` (server-only) and forwards
# the request server-side — eliminates CORS and hides the upstream
# host from the client.
#
#   V2_API_BASE_URL          — server-only; preferred. Set on Vercel.
#   NEXT_PUBLIC_API_BASE     — legacy override. When set, the client
#                               calls this URL directly instead of the
#                               proxy. Useful for local dev pointing at
#                               an ngrok tunnel.
V2_API_BASE_URL=
NEXT_PUBLIC_API_BASE=

# Event-chat attach (bot ↔ v2 backend). The bot Edge Function uses
# these to POST exported group invite links to the v2 backend's
# /internal/event-rooms/attach endpoint when a user creates a
# Telegram group via the Mini App's `?startgroup=event_<id>`
# deep-link. Both are required for the attach flow; if either is
# unset, scripts/deploy-functions.ts skips them and the bot will
# stay silent when added to event groups.
#
#   BACKEND_BASE_URL     — Railway URL of the v2 backend. Same value
#                           as V2_API_BASE_URL above; kept distinct so
#                           the proxy and the bot can be repointed
#                           independently.
#   BOT_INTERNAL_SECRET  — shared HMAC-SHA256 secret. Must match the
#                           value the v2 backend uses to verify the
#                           x-bot-signature header. Generate with
#                           `openssl rand -hex 32` and paste the same
#                           value here AND in the v2 backend's env.
BACKEND_BASE_URL=
BOT_INTERNAL_SECRET=
