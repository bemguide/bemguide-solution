PORT=8080
NODE_ENV=development
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Our own session-signing HS256 secret. Generate with: openssl rand -hex 32.
# Backend signs session tokens with this; auth-guard verifies locally.
# (We don't try to issue Supabase-compatible tokens — newer projects use ES256
# with a private key Supabase doesn't expose.)
SESSION_JWT_SECRET=
ACCESS_TOKEN_TTL_SECONDS=86400

CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=1m
LOG_LEVEL=info

# Telegram (initData login + bot-driven link tokens + worker outbound)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_LINK_SECRET=
TELEGRAM_LINK_TOKEN_TTL_SECONDS=900
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# Worker tunables
INVITATIONS_TOP_N=25
DISPATCH_BATCH_SIZE=50
ROOMS_PROVISION_BATCH_SIZE=20

# Set to 1 to run workers without hitting Telegram (logs intent only)
DRY_RUN=0

# Optional: server-generated ai_reason in /feed. Unset = empty string.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
